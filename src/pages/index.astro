---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCardFeatured from '../components/PostCardFeatured.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';

const posts = await getPublishedPosts();
const featuredPost = posts.length > 0 ? posts[0] : null;
const recentPosts = posts.length > 1 ? posts.slice(1, 5) : [];
const showRecentGrid = recentPosts.length >= 2;
const hasPosts = posts.length > 0;
---

<BaseLayout
  title="How Do I AI"
  description="AI first – for everything you do. Practitioner walkthroughs, tool assessments, and the parts that didn't work."
>
  <section class="hero" aria-label="Introduction">
    <h1 class="hero-brand">
      How Do I AI<span class="hero-question-mark">?</span>
    </h1>
    <p class="hero-tagline">
      <span class="accent">AI</span> first –
      <span class="accent">for</span> everything
      <span class="accent">you</span> do.
    </p>
    <p class="hero-descriptor">
      What works<span class="accent">?</span>
      When to use<span class="accent">?</span>
      How to do<span class="accent">?</span>
    </p>
  </section>

  {
    featuredPost && (
      <section class="featured" aria-label="Featured post">
        <h2 class="section-heading">Latest</h2>
        <PostCardFeatured post={featuredPost} />
      </section>
    )
  }

  {
    showRecentGrid && (
      <section class="recent" aria-label="Recent posts">
        <h2 class="section-heading">Recent</h2>
        <div class="recent-grid">
          {recentPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  {
    hasPosts && (
      <div class="cta">
        <a href="/blog/" class="cta-link">
          See all posts &rarr;
        </a>
      </div>
    )
  }
</BaseLayout>

<style>
  /* Hero section */
  .hero {
    text-align: center;
    padding: var(--space-section-y) var(--space-section-x);
  }

  .hero-brand {
    font-size: var(--text-fluid-hero);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .hero-question-mark {
    color: var(--color-accent);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-text);
    margin-block: var(--space-4) var(--space-2);
    /*
      text-wrap: balance prevents orange accent words (AI / for / you)
      from orphaning on the first or last line at narrow viewports per
      PDR-004 § Wrap behavior (2026-04-19 amendment). Accent-word
      position-independence: glyph-level emphasis follows the word
      wherever it wraps; orphaning breaks the visual rhythm of the
      Orange Accent Pattern. Baseline: Chrome 114+, Safari 17.5+,
      Firefox 121+; graceful fallback on older browsers is natural wrap.
    */
    text-wrap: balance;
  }

  .hero-descriptor {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-block: 0;
  }

  /* Section headings */
  .section-heading {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  /*
    Featured post section.
    Base (<480px): edge-to-edge — card visually spans viewport minus its own
    internal padding, per ux-architecture.md § Mobile § Home Page
    ("Featured card: full-width, single column").
    480px+: horizontal gutter restored via var(--space-4).
  */
  .featured {
    max-width: 48rem;
    margin-inline: auto;
    padding: var(--space-8) 0;
  }

  @media (min-width: 480px) /* --bp-sm */ {
    .featured {
      padding: var(--space-8) var(--space-4);
    }
  }

  /* Recent posts section */
  .recent {
    max-width: 64rem;
    margin-inline: auto;
    padding: var(--space-8) var(--space-4);
  }

  /*
    Recent grid — mobile-first responsive columns per
    ux-architecture.md § Mobile § Home Page:
      base (<480px): 1 column
      480-767px:     2 columns
      768px+:        auto-fill, minmax(min(100%, 18rem), 1fr) — original layout
  */
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 480px) /* --bp-sm */ {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) /* --bp-md */ {
    .recent-grid {
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    }
  }

  /* CTA */
  .cta {
    text-align: center;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  /*
    CTA link — base (<480px): full-width tap target per
    ux-architecture.md § Mobile § Home Page. min-height uses
    var(--touch-target) to satisfy REQ-A11Y-05 / REQ-MOB-03 via the
    canonical token (REQ-MOB-04). 480px+: inline-flex (original).
  */
  .cta-link {
    display: flex;
    width: 100%;
    justify-content: center;
    align-items: center;
    min-height: var(--touch-target);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  @media (min-width: 480px) /* --bp-sm */ {
    .cta-link {
      display: inline-flex;
      width: auto;
    }
  }

  .cta-link:hover {
    background-color: var(--color-surface);
    color: var(--color-teal);
  }
</style>
