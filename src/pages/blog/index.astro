---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogFilter from '../../components/BlogFilter.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="Blog — How Do I AI"
  description="Every post from How Do I AI — practitioner walkthroughs on applying AI to real work. Filter by pillar, series, or tag."
>
  <section class="blog-index">
    <div class="blog-header">
      <h1>Blog</h1>
      <p class="blog-subtitle">All posts — filter by pillar, series, or tag.</p>
    </div>

    <BlogFilter>
      {/*
        Visually-hidden h2 preserves the heading cascade: the h3 titles
        rendered by PostCard belong to this section (not the h1 page
        title). Without an intermediate h2, axe-core flags the h1 → h3
        jump (heading-order), failing QA-08 on blog-index.
      */}
      <h2 class="sr-only">Posts</h2>
      {
        posts.map((post) => (
          <div
            class="post-card-wrapper"
            data-pillar={post.data.pillar}
            data-series={post.data.series || ''}
            data-tags={post.data.tags.join(',')}
          >
            <PostCard post={post} />
          </div>
        ))
      }
    </BlogFilter>
  </section>
</BaseLayout>

<style>
  .blog-index {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .blog-header {
    margin-bottom: var(--space-8);
  }

  .blog-header h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .blog-subtitle {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin: 0;
  }
</style>
