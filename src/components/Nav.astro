---
import { getPostsByPillar } from '../lib/posts';
import ThemeToggle from './ThemeToggle.astro';
import { PILLARS } from '../lib/taxonomy';

interface Props {
  activePillar?: string;
}

const { activePillar } = Astro.props;

const metaPosts = await getPostsByPillar('meta');
const showMeta = metaPosts.length > 0;

// Nav surfaces all pillars except Meta, which only shows once there
// is at least one published post in that pillar.
const pillars = Object.entries(PILLARS)
  .filter(([slug]) => slug !== 'meta' || showMeta)
  .map(([slug, label]) => ({ slug, label }));
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="wordmark" aria-label="How Do I AI home">
      <span class="nav-mark" aria-hidden="true"></span>
      <span class="wordmark-text"
        >How Do I AI<span class="question-mark">?</span></span
      >
    </a>

    <div class="nav-links">
      <ul class="pillar-links" role="list">
        {
          pillars.map((pillar) => (
            <li>
              <a
                href={`/blog/?pillar=${pillar.slug}`}
                class:list={[
                  'pillar-link',
                  { active: activePillar === pillar.slug },
                ]}
              >
                {pillar.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="nav-actions">
        <ThemeToggle />

        <a href="/rss.xml" class="rss-icon-link" aria-label="RSS Feed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-surface);
  }

  /*
    Pattern A (PDR-006): mobile-first stacked layout. At <480px, wordmark
    sits centered above a wrapping pillar row, with .nav-actions on its
    own row. Focus-order guardrail (ux-architecture.md:140): no `order`,
    no `flex-direction: *-reverse`, no explicit grid placement on this
    subtree — DOM order is the reading order.
  */
  .nav-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-4);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    align-self: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .wordmark:hover {
    color: var(--color-text);
  }

  /*
    Pre-rasterized PNG, not inline SVG — small-size SVG rasterization in
    browsers produces aliased edges, so all logo placements use Lanczos
    downscales from the 8K PNG master per brand HQ convention. Asset
    provenance + the rasterization rule reference live in
    public/brand/SOURCE.md. Theme variant tracks .dark class (set
    pre-paint by BaseHead inline script); both variants preloaded in
    BaseHead.
  */
  .nav-mark {
    display: inline-block;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    /*
      Three layers of progressive enhancement:
      1. url() — single 1x PNG; works everywhere including Safari ≤16,
         Chrome <113, but no HiDPI selection.
      2. -webkit-image-set() — older WebKit/Blink that only supports the
         prefixed form gets HiDPI variant selection.
      3. image-set() — modern unprefixed (Safari 17+, Chrome 113+).
      Browsers parse each in order and use the last one they understand.
    */
    background-image: url('/brand/nav-mark-light.png');
    background-image: -webkit-image-set(
      url('/brand/nav-mark-light.png') 1x,
      url('/brand/nav-mark-light@2x.png') 2x,
      url('/brand/nav-mark-light@3x.png') 3x
    );
    background-image: image-set(
      url('/brand/nav-mark-light.png') 1x,
      url('/brand/nav-mark-light@2x.png') 2x,
      url('/brand/nav-mark-light@3x.png') 3x
    );
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  :global(:root.dark) .nav-mark {
    background-image: url('/brand/nav-mark-dark.png');
    background-image: -webkit-image-set(
      url('/brand/nav-mark-dark.png') 1x,
      url('/brand/nav-mark-dark@2x.png') 2x,
      url('/brand/nav-mark-dark@3x.png') 3x
    );
    background-image: image-set(
      url('/brand/nav-mark-dark.png') 1x,
      url('/brand/nav-mark-dark@2x.png') 2x,
      url('/brand/nav-mark-dark@3x.png') 3x
    );
  }

  .question-mark {
    color: var(--color-accent);
  }

  .nav-links {
    /* Base (<480px): stack pillar row above actions row. */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .pillar-links {
    /* Visible wrapping flex row — no overflow scroll. Row gap ≥16px
       preserves typographic rhythm when wrapping (PDR-006 constraint 2). */
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    row-gap: var(--space-4);
    column-gap: var(--space-2);
    list-style: none;
  }

  .pillar-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    min-height: var(--touch-target);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: 500; /* Medium 500 base; wordmark stays strongest at 700 */
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .pillar-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface);
  }

  /*
    Active state per ux-architecture.md:126-130 (amended 2026-04-19):
    the weight step Medium 500 → Semibold 600 is the PRIMARY state
    indicator. --color-surface background is decorative — measured 1.06:1
    light / 1.19:1 dark contrast against page bg is below SC 1.4.11's 3:1,
    but justified because the weight step carries state independently of
    color (SC 1.4.11 "required to identify" clause). color-text on
    color-surface itself is 15.04:1 light / 10.32:1 dark (passes SC 1.4.3
    AAA). Do NOT restore --color-accent on active — that was the
    pre-amendment rule (Signal Orange is reserved for tagline signature
    per PDR-004 and would dilute the brand-signature device).
  */
  .pillar-link.active {
    color: var(--color-text);
    background-color: var(--color-surface);
    font-weight: 600;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .rss-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .rss-icon-link:hover {
    color: var(--color-accent);
  }

  /* 480-767px: .nav-links flexes to row; pillar-links keep `flex-wrap: wrap`
     (inherited from base) and collapse to one row ONLY when geometry allows.
     Historic "at 480px+ collapse to single row" rule (PDR-006 original
     constraint 4) was superseded 2026-04-19 after PR #99 fresh-context review
     surfaced B1: 3 pillars + gaps need ~413px but space-between allocates
     ~316px at 480vp, causing the active pillar chip to overlap .nav-actions.
     Current amendment (PDR-006 § Cascade log 2026-04-19, part 3): wrap is
     invariant across 0-767px; single-row is an emergent outcome, not enforced.
     Do NOT reintroduce `flex-wrap: nowrap` here — it was the B1 root cause. */
  @media (min-width: 480px) /* --bp-sm */ {
    .nav-links {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .pillar-links {
      justify-content: flex-start;
      column-gap: var(--space-2);
      flex: 1;
      min-width: 0;
    }
  }

  /* 768px+: desktop — wordmark left, pillars center-right, actions far right */
  @media (min-width: 768px) /* --bp-md */ {
    .nav-inner {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
    }

    .wordmark {
      align-self: auto;
    }

    .nav-links {
      flex: 1;
      justify-content: flex-end;
    }
  }
</style>
